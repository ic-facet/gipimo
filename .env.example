# Configuración de producción para LAVNet
# Copia este archivo a .env y configura las variables

# SECURITY WARNING: keep the secret key used in production secret!
# Genera una nueva con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=tu-secret-key-super-segura-aqui

# SECURITY WARNING: don't run with debug turned on in production!
DEBUG=False

# Hosts permitidos (separados por comas sin espacios)
ALLOWED_HOSTS=gipimo.ddns.net,localhost,127.0.0.1

# Base de datos (opcional - por defecto usa SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/lavnet_db

# Configuración de Gunicorn
GUNICORN_WORKERS=3
GUNICORN_BIND=0.0.0.0:8000
